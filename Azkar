<!DOCTYPE html>
<html lang="ar">
<head>
<meta charset="UTF-8">
<title>أذكار الصباح والمساء</title>
<style>
body{
font-family: Arial;
direction: rtl;
text-align: center;
background:#f5f5f5;
}
.zekr{
background:white;
padding:20px;
margin:15px;
border-radius:10px;
}
button{
padding:10px 20px;
font-size:18px;
}
</style>
</head>

<body>

<h1>أذكار الصباح والمساء</h1>

<div class="zekr">
<p>سبحان الله وبحمده</p>
<p>العدد المطلوب: 100</p>
<button onclick="count1++ ; document.getElementById('c1').innerText=count1">اضغط</button>
<p id="c1">0</p>
</div>

<div class="zekr">
<p>أستغفر الله</p>
<p>العدد المطلوب: 100</p>
<button onclick="count2++ ; document.getElementById('c2').innerText=count2">اضغط</button>
<p id="c2">0</p>
</div>

<script>
let count1=0;
let count2=0;
</script>

</body>
</html>
